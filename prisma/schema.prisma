generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExamType {
  JEE
  NEET
}

enum SubjectEnum {
  PHYSICS
  CHEMISTRY
  MATHEMATICS
  ZOOLOGY
  BOTANY
}

enum QuestionType {
  MCQ
  NUMERICAL
  MULTI_CORRECT
}

enum Difficulty {
  EASY
  MODERATE
  HARD
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  MARKS_UPLOADED
  TEST_RESULT
  RANK_UPDATE
  WEAK_AREA_ALERT
  PARENT_NOTIFIED
  ASSIGNMENT
  GENERAL
}

enum RoleEnum {
  USER
  STUDENT
  FACULTY
  ADMIN
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  role          RoleEnum @default(USER)
  createdAt     DateTime
  updatedAt     DateTime

  faculty       Faculty?
  student       Student?
  notifications Notification[]
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Student {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  rollNo      String    @unique
  targetExam  ExamType  @default(JEE)
  batchId     String?
  batch       Batch?    @relation(fields: [batchId], references: [id])
  parentName  String?
  parentPhone String?
  parentEmail String?
  address     String?
  dob         DateTime?

  marks           Mark[]
  testAttempts    TestAttempt[]
  weakAreas       WeakArea[]
  rankPredictions RankPrediction[]
  attendances     Attendance[]
  whatsappLogs    WhatsAppLog[]
}

model Faculty {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id])
  title      String?
  department String?

  questions Question[]
  mockTests MockTest[]
  marks     Mark[]         @relation("FacultyMarks")
  batches   BatchFaculty[]
}

model Batch {
  id        String   @id @default(cuid())
  name      String
  examType  ExamType
  year      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  students  Student[]
  faculties BatchFaculty[]
  mockTests MockTest[]
}

model BatchFaculty {
  batchId   String
  facultyId String
  batch     Batch   @relation(fields: [batchId], references: [id])
  faculty   Faculty @relation(fields: [facultyId], references: [id])

  @@id([batchId, facultyId])
}

model Topic {
  id      String      @id @default(cuid())
  name    String
  subject SubjectEnum

  questions Question[]
  weakAreas WeakArea[]
}

model Question {
  id         String       @id @default(cuid())
  text       String
  type       QuestionType @default(MCQ)
  difficulty Difficulty   @default(MODERATE)
  subject    SubjectEnum

  topicId     String?
  topic       Topic?   @relation(fields: [topicId], references: [id])
  facultyId   String
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  explanation String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  options           QuestionOption[]
  answers           StudentAnswer[]
  mockTestQuestions MockTestQuestion[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int
}

model MockTest {
  id   String @id @default(cuid())
  name String

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  facultyId String
  faculty   Faculty @relation(fields: [facultyId], references: [id])

  duration              Int
  totalMarks            Int
  totalMarksPhysics     Int?
  totalMarksChemistry   Int?
  totalMarksMathematics Int?
  totalMarksZoology     Int?
  totalMarksBotany      Int?
  isPublished           Boolean   @default(false)
  scheduledAt           DateTime?
  createdAt             DateTime  @default(now())

  questions MockTestQuestion[]
  attempts  TestAttempt[]
}

model MockTestQuestion {
  id         String   @id @default(cuid())
  mockTestId String
  mockTest   MockTest @relation(fields: [mockTestId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  orderIndex Int
  marks      Int      @default(4)
  negMarks   Float    @default(1)
}

model TestAttempt {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  mockTestId String
  mockTest   MockTest @relation(fields: [mockTestId], references: [id])

  startedAt        DateTime  @default(now())
  submittedAt      DateTime?
  physicsMarks     Float?
  chemistryMarks   Float?
  mathematicsMarks Float?
  zoologyMarks     Float?
  botanyMarks      Float?
  totalScore       Float?
  percentile       Float?
  timeTaken        Int?

  answers StudentAnswer[]

  @@index([studentId, mockTestId])
}

model StudentAnswer {
  id               String      @id @default(cuid())
  attemptId        String
  attempt          TestAttempt @relation(fields: [attemptId], references: [id])
  questionId       String
  question         Question    @relation(fields: [questionId], references: [id])
  selectedOptionId String?
  numericalAnswer  Float?
  isCorrect        Boolean?
  marksAwarded     Float?
  timeTaken        Int?
}

model Mark {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  facultyId String
  faculty   Faculty @relation("FacultyMarks", fields: [facultyId], references: [id])

  subject       SubjectEnum
  testName      String
  examType      ExamType
  marksObtained Float
  maxMarks      Float
  percentile    Float?
  improvement   Float?
  batchId       String?
  createdAt     DateTime    @default(now())

  @@index([studentId, subject, examType])
}

model RankPrediction {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  examType         ExamType
  percentile       Float
  predictedRank    Int
  targetPercentile Float?
  targetRank       Int?
  improvementPts   Float
  createdAt        DateTime @default(now())
}

model WeakArea {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  topicId        String
  topic          Topic    @relation(fields: [topicId], references: [id])
  drawbackPoints Float
  questionsCount Int      @default(0)
  priority       Priority @default(HIGH)
  updatedAt      DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  date      DateTime
  isPresent Boolean  @default(true)
  subject   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  parentPhone String
  message     String
  status      String
  sentAt      DateTime @default(now())
  metadata    Json?
}

// auth specific models

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
